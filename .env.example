# =============================================================================
# Railway — PostgreSQL
# Prisma (`packages/db`), API, and tests use this connection string.
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/famlink"

# =============================================================================
# Clerk — authentication (Next.js + Express + webhooks)
# Dashboard: https://dashboard.clerk.com — API keys, JWT, webhook signing secret.
# =============================================================================
CLERK_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_WEBHOOK_SECRET="whsec_placeholder"
# Paths Clerk uses for hosted sign-in/up and post-auth redirects (apps/web).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# =============================================================================
# Express API (apps/api)
# Server port, CORS origin, and Jest test DB (see apps/api/.env.example).
# =============================================================================
PORT="3001"
NODE_ENV="development"
WEB_APP_URL="http://localhost:3000"
GUEST_TOKEN_SECRET="replace_with_a_long_random_secret"
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/famlink_test"

# =============================================================================
# Resend — outbound email (invitations, notifications)
# =============================================================================
RESEND_API_KEY="re_placeholder"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# =============================================================================
# Twilio — SMS (invitations, notifications)
# =============================================================================
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15555551234"

# =============================================================================
# Firebase — FCM push (Phase 1 notifications; service account in production)
# =============================================================================
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# =============================================================================
# AI providers (optional; future features)
# =============================================================================
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
HELICONE_API_KEY=""

# =============================================================================
# Turborepo — remote cache (optional)
# =============================================================================
TURBO_TOKEN=""
TURBO_TEAM=""

# =============================================================================
# Next.js — browser-visible URLs (apps/web)
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
