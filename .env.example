# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/famlink"

# ─── Authentication (Clerk) ─────────────────────────────────
CLERK_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_WEBHOOK_SECRET="whsec_placeholder"
# Next.js (apps/web) — also copy into apps/web/.env.local
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── API server (Express) — mirror in apps/api/.env when running API ─
PORT="3001"
WEB_APP_URL="http://localhost:3000"
GUEST_TOKEN_SECRET="replace_with_a_long_random_secret"

# ─── AI Providers ───────────────────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ─── AI Monitoring ──────────────────────────────────────────
HELICONE_API_KEY=""

# ─── Notifications ──────────────────────────────────────────
RESEND_API_KEY="re_placeholder"
RESEND_FROM_EMAIL="onboarding@resend.dev"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15555551234"
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ─── Turborepo Remote Cache (optional) ──────────────────────
TURBO_TOKEN=""
TURBO_TEAM=""

# ─── App URLs ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
