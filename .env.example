# =============================================================================
# Monorepo environment — copy to `.env` and/or `.env.local` at this repo root
# =============================================================================
#
# Where things live (you do NOT need `apps/api/.env` unless you want it):
#
#   • `.env` — shared local defaults (this repo gitignores `**/.env`; copy from here).
#   • `.env.local` — local secrets (gitignored). Put real keys here so they never ship
#     in a template. Example: Firebase service account, production-like secrets.
#
# Load order when you run `npm run dev` in `apps/api` (see `apps/api/src/loadEnv.ts`):
#   1) `apps/api/.env` if the file exists
#   2) this root `.env`
#   3) this root `.env.local`
# Dotenv does not overwrite an already-set variable, so the first file that *sets*
# a key wins. Avoid defining the same key in multiple files with different values.
#
# Jest / API tests use `apps/api/.env.test` (see that file + `loadDotenvTest.ts`), not
# this file, for `TEST_DATABASE_URL`. Test runs also apply safe placeholder Firebase
# defaults so you usually do not put real `FIREBASE_*` in `.env.test`.
#
# Production (e.g. Railway): set the same variable names in the API service dashboard.
#
# =============================================================================
# Railway — PostgreSQL
# Prisma (`packages/db`), API, and tests use this connection string.
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/famlink"

# =============================================================================
# Clerk — authentication (Next.js + Express + webhooks)
# Dashboard: https://dashboard.clerk.com — API keys, JWT, webhook signing secret.
# =============================================================================
CLERK_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
# Express API (`apps/api`) — same key as NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_WEBHOOK_SECRET="whsec_placeholder"
# Paths Clerk uses for hosted sign-in/up and post-auth redirects (apps/web).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"
# Keyless Clerk onboarding is turned off in apps/web/next.config.mjs (avoids Next 14 server-action issues).

# =============================================================================
# Express API (apps/api)
# =============================================================================
PORT="3001"
NODE_ENV="development"
WEB_APP_URL="http://localhost:3000"
GUEST_TOKEN_SECRET="replace_with_a_long_random_secret"
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/famlink_test"

# =============================================================================
# Resend — outbound email (invitations, notifications)
# Verified domain in Resend — from addresses use invites@ and notifications@{DOMAIN}
# =============================================================================
RESEND_API_KEY="re_placeholder"
RESEND_FROM_DOMAIN="mail.yourdomain.com"

# =============================================================================
# Twilio — SMS (invitations, notifications)
# =============================================================================
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15555551234"

# =============================================================================
# Firebase Admin — FCM push notifications (apps/api only; P1-11)
# =============================================================================
# Get these from one Firebase / Google Cloud service account JSON:
#   Firebase Console → Project settings → Service accounts → Generate new private key
#
# Map JSON → env (exactly three variables):
#   FIREBASE_PROJECT_ID     ←  "project_id"
#   FIREBASE_CLIENT_EMAIL   ←  "client_email"
#   FIREBASE_PRIVATE_KEY    ←  "private_key"
#
# FIREBASE_PRIVATE_KEY must stay ONE LINE in .env inside double quotes. Copy the
# JSON value as-is: it already uses \n between PEM lines. Keep the characters \
# and n — do not replace them with real line breaks in the file.
#
# Example shape (ellipsis = rest of key):
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# Dev/staging/prod: you may use the same three values everywhere, or separate Firebase
# projects per environment. Railway: add the same names to the API service variables.
#
# Tests: `apps/api` Jest uses placeholder Firebase in `loadTestEnv.ts` unless you
# override; you normally do NOT paste real keys into `apps/api/.env.test`.
# =============================================================================
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# =============================================================================
# AI providers (optional; future features)
# =============================================================================
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
HELICONE_API_KEY=""

# =============================================================================
# Turborepo — remote cache (optional)
# =============================================================================
TURBO_TOKEN=""
TURBO_TEAM=""

# =============================================================================
# Next.js — browser-visible URLs (apps/web)
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
