# Copy to `.env.test` (gitignored) and fill in your Railway `famlink_test` URL.
# Jest loads this via dotenv in some setups; `loadTestEnv` also requires TEST_DATABASE_URL.
#
# Required for `npm test` (globalSetup runs `prisma migrate deploy` against this URL).

TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/famlink_test
