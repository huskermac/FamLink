# Copy to `apps/api/.env.test` (gitignored) or edit that file directly.
# `loadDotenvTest` + dotenv load this before Jest globalSetup and tests.
#
# Required for `npm test` (globalSetup runs `prisma migrate deploy` against this URL).
#
# Railway: use the Postgres PUBLIC connection URL (e.g. *.rlwy.net). Do NOT use
# `*.railway.internal` — that host only works inside Railway’s network, not from your PC.

TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/famlink_test
