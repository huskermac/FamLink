# =============================================================================
# FamLink API — environment variables
# =============================================================================
#
# The running API loads env in this order (see `src/loadEnv.ts`):
#   1) `apps/api/.env` — optional; create only if you want API-only vars here
#   2) repo root `.env`
#   3) repo root `.env.local`
#
# You can keep everything in the repo root `.env` / `.env.local` and never create
# `apps/api/.env`. The first file that sets a variable wins (dotenv does not overwrite).
#
# For a full monorepo template including Clerk + web, see the repo root `.env.example`.
#
# =============================================================================
# Railway — PostgreSQL
# Used by Prisma and `DATABASE_URL` validation in `src/lib/env.ts`.
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/famlink

# =============================================================================
# Clerk — Express JWT + Svix webhook verification
# `CLERK_SECRET_KEY`: API verifies session JWTs.
# `CLERK_PUBLISHABLE_KEY`: same value as Next.js `NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY`.
# `CLERK_WEBHOOK_SECRET`: Svix signing secret for `POST /api/v1/webhooks/clerk`.
# =============================================================================
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_WEBHOOK_SECRET=whsec_placeholder

# =============================================================================
# Resend — email (required at API startup)
# Verified domain in Resend — used as invites@{RESEND_FROM_DOMAIN} and
# notifications@{RESEND_FROM_DOMAIN}
# =============================================================================
RESEND_API_KEY=re_placeholder
RESEND_FROM_DOMAIN=mail.yourdomain.com

# =============================================================================
# Twilio — SMS (required at API startup)
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555551234

# =============================================================================
# Guest links — JWT for RSVP without a Clerk session (P1-04)
# =============================================================================
GUEST_TOKEN_SECRET=change_me_to_a_long_random_string

# =============================================================================
# Express — bind address and CORS
# `WEB_APP_URL` must match the Next.js origin that calls this API.
# =============================================================================
PORT=3001
NODE_ENV=development
WEB_APP_URL=http://localhost:3000

# =============================================================================
# Firebase Admin — FCM push (P1-11)
# =============================================================================
# 1) Firebase Console → your project → Project settings (gear) → Service accounts
# 2) Generate new private key → download JSON
# 3) Set exactly these three variables from the JSON file:
#      FIREBASE_PROJECT_ID    ←  project_id
#      FIREBASE_CLIENT_EMAIL  ←  client_email
#      FIREBASE_PRIVATE_KEY   ←  private_key
#
# Put FIREBASE_PRIVATE_KEY on ONE line in double quotes. Use the JSON string as
# copied from the file: it contains \n between PEM lines. Keep those two characters
# (backslash + n); do not split the key across multiple lines in .env.
#
# Example:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# Local: add to repo root `.env.local` (recommended for secrets) or root `.env`.
# Production: same variable names on Railway (API service). Values are often identical
# for dev and prod early on (one Firebase project), or use separate projects later.
#
# Jest: `npm test` uses `apps/api/.env.test` plus `src/__tests__/setup/loadTestEnv.ts`
# placeholder Firebase — you normally do NOT put real Firebase secrets in `.env.test`.
# =============================================================================
FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-gcp-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# =============================================================================
# Jest — isolated DB for `npm test` (migrations via globalSetup)
# Copy this file to `apps/api/.env.test` and set TEST_DATABASE_URL only.
# Do not commit real secrets; this file is gitignored as `**/.env.test`.
# =============================================================================
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/famlink_test

# =============================================================================
# Cloudflare R2 — photo storage (P2-10)
# Create an R2 bucket in the Cloudflare dashboard, then generate an API token
# with Object Read & Write permissions. Enable public access on the bucket and
# set CLOUDFLARE_R2_PUBLIC_URL to its public endpoint.
# =============================================================================
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=famlink-photos
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
