# =============================================================================
# Railway — PostgreSQL
# Used by Prisma and `DATABASE_URL` validation in `apps/api/src/lib/env.ts`.
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/famlink

# =============================================================================
# Clerk — Express JWT + Svix webhook verification
# `CLERK_SECRET_KEY`: API verifies session JWTs.
# `CLERK_WEBHOOK_SECRET`: Svix signing secret for `POST /api/v1/webhooks/clerk`.
# =============================================================================
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_WEBHOOK_SECRET=whsec_placeholder

# =============================================================================
# Resend — email (required at API startup; invitations in later prompts)
# =============================================================================
RESEND_API_KEY=re_placeholder

# =============================================================================
# Twilio — SMS (required at API startup; invitations in later prompts)
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555551234

# =============================================================================
# Guest links — JWT for RSVP without a Clerk session (P1-04)
# =============================================================================
GUEST_TOKEN_SECRET=change_me_to_a_long_random_string

# =============================================================================
# Express — bind address and CORS
# `WEB_APP_URL` must match the Next.js origin that calls this API.
# =============================================================================
PORT=3001
NODE_ENV=development
WEB_APP_URL=http://localhost:3000

# =============================================================================
# Jest — isolated DB for `npm test` (migrations via globalSetup)
# =============================================================================
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/famlink_test
