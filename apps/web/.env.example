# =============================================================================
# Clerk — Next.js + Express
# `next.config.mjs` loads the monorepo root `.env` / `.env.local`, so you can
# keep a single env file at the repo root. Or duplicate those vars here.
# Publishable key is exposed to the browser; secret is server-only.
#
# Firebase / FCM: configured only on the Express API (see repo root `.env.example`
# and `apps/api/.env.example`). The web app does not need FIREBASE_* for Phase 1.
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
# Default off in next.config.mjs — avoids keyless server-action issues on Next 14.
# NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=1

# =============================================================================
# Next.js — public URLs (browser)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
